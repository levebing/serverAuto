# .env 文件内容
# 密钥
SECRET_KEY=server_auto_inspection_secret_key
#告警阈值
MAX_ALERT_THRESHOLD=80
#服务端口
PORT=5000

# 数据库配置
# 数据库类型: sqlite, postgresql, mysql
DATABASE_TYPE=sqlite
# SQLite 配置（当 DATABASE_TYPE=sqlite 时使用）
DATABASE_NAME=servers.db
# PostgreSQL 配置（当 DATABASE_TYPE=postgresql 时使用）
DB_HOST=192.168.30.13
DB_PORT=9432
DB_USER=postgres
DB_PASSWORD=dcjt@4567
DB_DATABASE=server_auto

# 文件上传
# 上传类型: local(本地) 或 external(外部服务)
UPLOAD_TYPE=local
# 当 UPLOAD_TYPE=local 时，本地存储路径（相对于项目根目录）
UPLOAD_LOCAL_PATH=upload
# 当 UPLOAD_TYPE=local 时，访问文件的基础URL
UPLOAD_LOCAL_BASE_URL=http://localhost:5000
# 当 UPLOAD_TYPE=external 时，外部上传服务地址
UPLOAD_URL=http://192.168.30.189:9035/uploader
#文件上传超时时间
UPLOAD_TIMEOUT=30

# 报告存储
REPORT_BASE_URL=http://192.168.30.189:9035
# 密码加密密钥（重要：生产环境请使用环境变量配置）
ENCRYPTION_KEY=u5DriJCI9KBRrCD__P_345u0NxC82W1wIfQ9w9Y19QQ=